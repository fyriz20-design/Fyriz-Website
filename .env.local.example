# ── Supabase ────────────────────────────────────────────────────────────────
# Zu finden unter: supabase.com → Dein Projekt → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NUR serverseitig!

# ── Resend (E-Mail-Versand) ──────────────────────────────────────────────────
# Zu finden unter: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Die Adresse, an die Kontaktanfragen weitergeleitet werden
CONTACT_EMAIL=deine@email.de

# ── Vercel Blob (Bilder-Upload im Admin) ────────────────────────────────────
# Automatisch gesetzt wenn du in Vercel unter Storage → Blob ein Store anlegst
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxx
